# Copy to .env and adjust. docker compose auto-loads .env from this directory.

# --- Toolchain versions (rebuild after changing: `docker compose build`) ----
GO_VERSION=1.25.7
NODE_MAJOR=24
POSTGRES_VERSION=16

# --- What to mount at /workspace --------------------------------------------
# Default is this folder. Point at another repo to develop it in here, e.g.:
#   WORKSPACE=../my-app
#   WORKSPACE=/home/you/github/my-app   (Linux/WSL2)
#   WORKSPACE=C:/Users/you/github/my-app (native Windows)
WORKSPACE=/Users/guest1/Document/cobaltspeech/Project

# --- Postgres ---------------------------------------------------------------
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev
POSTGRES_DB=app
POSTGRES_PORT=5432

# --- Host ports for dev servers ---------------------------------------------
WEB_PORT=3000
API_PORT=8080
ADMINER_PORT=8090
